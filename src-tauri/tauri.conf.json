{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "windsurf-account-manager",
  "version": "1.7.4",
  "identifier": "com.chao.windsurf-account-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:46952",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "windsurf-account-manager-simple",
        "width": 1200,
        "height": 800,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/chaogei/windsurf-account-manager-simple/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4RjBEMDc2QzNFOTA2MUMKUldRY0J1bkRkdER3T0EzUGZPVjI2ejNRanpwTjlWVlkzckxCRDRMWDhZR29kRG51V0hiL1llYTMK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    },
    "resources": {
      "windsurf-account-manager.exe.manifest": "",
      "cunzhi-bundle/*": "cunzhi/"
    }
  }
}
